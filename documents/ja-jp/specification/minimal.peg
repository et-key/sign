_ = [ ]*
__ = [ ]+

Expression
  = Define
  / Apply
  / Lambda
  / Product
  / (name / number)
  / ""
  
  Define = name _ ":" _ Expression

  Apply = Lambda __ Expression

  Lambda = Product _ "?" _ (Lambda / Product / Expression)
 
  Product = (name / number) _ (__ / ",") _ Expression
  
  name = [a-zA-Z_] [0-9a-zA-Z_]*
  
  number = "-"? [0-9]+
