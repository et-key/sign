_ = [ ]*
__ = [ ]+

Expression
  = Define
  / Apply
  / Lambda
  / Product
  / Value

Define  = name _ ":" _ Expression

Apply   = Lambda __ Expression

Lambda  = name (__ name)* _ "?" _ Expression

Product = Value (_ (__ / ",") _ Expression)?

Value   = name / number

name    = [a-zA-Z_] [0-9a-zA-Z_]*
number  = "-"? [0-9]+