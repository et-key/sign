list_a : [1, 2]
list_b : [3, 4]
concat_list : list_a list_b
_ : 1 # concat_list

_ : 1 # `--- 2D Array Spread ---`
_ : 1 # [[10, 20], [30, 40]]~

` =========================================================
_ : 1 # `===== Ph6: Advanced Memory (Escape) =====`
` =========================================================
f : x ? (
	y : 100
	g : z ? x + y + z
	g
)
my_func : f 50
_ : 1 # my_func 10


` 2. Address Operator ($)
test_addr : (
	val : 42
	$val
)
_ : 1 # `Address of val is:`
_ : 1 # test_addr

` =========================================================
_ : 1 # `===== Ph7: Compiler Optimization =====`
` =========================================================

` 1. Constant Folding (定数畳み込み)
` JS側で事前計算され、WASMには 70 だけが出力される
_ : 1 # 10 + 20 * 3

` 2. Static Dispatch (静的ディスパッチ)
` 関数ではない空白適用が実行時判定をスキップし、直接リストに置換される
_ : 1 # 100 200

` 3. Beta Reduction (インライン展開)
` クロージャが生成されず、即座に 20 + 10 が計算されて出力される
_ : 1 # (x ? x + 10) 20

` =========================================================
_ : 1 # `===== Ph8: Math Operators =====`
` =========================================================

` 1. Absolute Value (絶対値)
` 定数畳み込み（JS側で事前計算されるパターン）
_ : 1 # |-42|

` ランタイム実行（WASM側で f64.abs が呼ばれるパターン）
f : x ? |x|
_ : 1 # f -99

` 2. Factorial (階乗)
_ : 1 # 5!

` =========================================================
_ : 1 # `===== Ph9: Dynamic List =====`
` =========================================================
_ : 1 # `--- Range  ---`
` 1. 昇順リスト
_ : 1 # 1 ~ 5

` 2. 降順リスト (自動で逆向きに生成)
_ : 1 # 5 ~ 1

` 3. 浮動小数点のRange (賢く小数点ステップを解釈)
_ : 1 # 1.5 ~ 4.0

_ : 1 # `--- Lift Operator  ---`
` 1. 単一の値を持ち上げてリストにする
_ : 1 # ~42

` 2. Spread (後置) と Lift (前置) の対称性の確認
list : 10, 20
_ : 1 # ~(list~)

