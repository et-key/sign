` =========================================================
_ : 1 # `===== Ph1 =====`
` =========================================================
` --- 比較演算 ---
ph1_cmp : (5 == 5), (1 != 2), (1 < 2), (2 > 1), (1 <= 1), (2 >= 2)
_ : 1 # ph1_cmp~

` --- 論理演算 (0, 1 は Truthy, _ は Falsy) ---
ph1_log : (_ & 0), (0 & _), (0 & 1), (_ | 0), (0 | _), (0 | 1), (_ ; 0), (1 ; _), (0 ; 1), (_ ; _)
_ : 1 # ph1_log~

` --- ビット演算 ---
ph1_bit : (1 && 42), (0 || 99), (1 ;; 1), (1 ;; 0), (1 << 2), (4 >> 1), (!!0)
_ : 1 # ph1_bit~

` --- その他制御・単項演算 ---
ph1_oth : (!1), (!(1 == 2)), ((1 == 1) : 100), ((1 == 2) : 200), (x ? x + 1)
_ : 1 # ph1_oth~


` =========================================================
_ : 1 # `===== Ph2 =====`
` =========================================================
` テスト1: 文字列（Strings）の割り当てと出力
` ※SVCによるストリーム出力を使うため ~ を外しています
_ : 1 # `Hello! WASM Strings!`

` テスト2: リスト作成と結合 (cons と ,)
list_test : 100, 200
_ : 1 # list_test~

` テスト3: リスト要素の抽出 (head, tail)
ph2_ext : (list_test ' 0), (list_test ' 1)
_ : 1 # ph2_ext~

` テスト4: ブロックの短絡評価 ([...])
_ : 1 # [ _ 42 99 ]


` =========================================================
_ : 1 # `===== Ph3 =====`
` =========================================================
` 1.クロージャの生成と適用
f : x y ?
	x + y
ph3_closure : f 10 20, (f 10 20), (f (10 20)), ((f 10) 20)
_ : 1 # ph3_closure~

_ : 1 # [x y ? x + y] 10 20

` 2.`match_case` (条件分岐) の機能
match_test : x ?
	x = 0 : 100
	x > 0 : 200
	x < 0 : 300
	400
ph3_match : (match_test 0), (match_test 1), (match_test -1), (match_test _), (match_test `a`), (match_test a)
_ : 1 # ph3_match~

` 3.カッコブロック `[]` を用いた辞書の生成とアクセス
dict_test : x ?
	[
		id : x
		val : x + 2
	]

my_dict : dict_test 40
ph3_dict : (my_dict ' id), (my_dict ' val)
_ : 1 # ph3_dict~

` 4.Match Case と辞書環境の統合テスト
complex_test : code ?
	code == 200 : [
		status : 200
		msg : 1
	]
	code == 404 : [
		status : 404
		msg : 0
	]
	[
		status : 500
		msg : -1
	]

res1 : complex_test 200
res2 : complex_test 404
res3 : complex_test _
res4 : complex_test a
ph3_complex : (res1 ' status), (res1 ' msg), (res2 ' status), (res2 ' msg), (res3 ' status), (res3 ' msg), (res4 ' status), (res4 ' msg)
_ : 1 # ph3_complex~


` =========================================================
_ : 1 # `===== Ph3.5 =====`
` =========================================================
` 1. 算術・論理演算子のオペランド欠落
test_math_R : 10 +
test_math_L : * 5
test_logic_R : 1 &
ph35_1 : test_math_R, test_math_L, test_logic_R
_ : 1 # ph35_1~

` 2. 辞書の定義エラーとプロパティアクセスの崩壊
test_dict_bad : [ : 100 ]
test_prop_bad : test_dict_bad ' missing
ph35_2 : test_dict_bad, test_prop_bad
_ : 1 # ph35_2~

` 3. 関数定義（ラムダ構築子）の構文エラー
test_lambda_empty : x ?
test_lambda_no_arg : ?
	10
ph35_3 : test_lambda_empty, test_lambda_no_arg
_ : 1 # ph35_3~

` 4. 演算子の関数化（ポイントフリー）での中身の崩壊
test_pf_empty : []
test_pf_bad_op : [+ -]
test_pf_bad_apply : [10 + *]
ph35_4 : test_pf_empty, test_pf_bad_op, test_pf_bad_apply
_ : 1 # ph35_4~

` 5. 関数合成・適用における引数不足（カリー化・クロージャ返却の検証）
test_compose_short : [+ 2] [* 5] [+] 4
_ : 1 # test_compose_short

` 6. インデントブロックにおけるパイプライン連鎖の検証
test_pipeline : [
	* 2
	10
]
_ : 1 # test_pipeline


