` 1. ポイントフリー記法（関数合成）のテスト
foo : [+ 4]
bar : [* 3]
baz : 2
_ : 1 # foo bar baz

test_pf_multi : [+ 3] [* 2] [- 4] 5
_ : 1 # test_pf_multi

test_pf_pipe : [+ 5] [/ 3] 10
_ : 1 # test_pf_pipe

f_pipe : [* 3] [+ 10]
test_pf_bind : f_pipe 4
_ : 1 # test_pf_bind

test_pf_short2 : [+ 2] [* 5] [+] 4
_ : 1 # test_pf_short2

` 2. 部分適用（カリー化）のテスト
f1 : 10 +
_ : 1 # f1 5

f2 : + 2
_ : 1 # f2 10

f3 : +
f4 : f3 100
_ : 1 # f4 50

f5 : [10 * 2] +
_ : 1 # f5 3


