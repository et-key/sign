_ : 1 # 0 & _
_ : 1 # 0 & 1
_ : 1 # _ | 0
_ : 1 # 0 | _
_ : 1 # 0 | 1
_ : 1 # _ ; 0
_ : 1 # 1 ; _
_ : 1 # 0 ; 1
_ : 1 # _ ; _

_ : 1 # `--- Bitwise ---`
_ : 1 # 1 && 42
_ : 1 # 0 || 99
_ : 1 # 1 ;; 1
_ : 1 # 1 ;; 0
_ : 1 # 1 << 2
_ : 1 # 4 >> 1
_ : 1 # !!0

_ : 1 # `--- Other Control & Unary Operators ---`
