func_with_defaults:
		x: 1
		y: x + 1
	?
		x + y

result1_is_partial_applyed : func_with_defaults _
result2_is_applied : func_with_defaults 3
result3_is_partial_applyed : func_with_defaults _ , 5
result4_is_applied : func_with_defaults 3 5

